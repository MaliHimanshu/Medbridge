# ==========================================
# PostgreSQL Database
# ==========================================

DATABASE_URL="postgresql://username:password@localhost:5432/medbridge"

# ==========================================
# JWT Secret
# ==========================================

JWT_SECRET="your_jwt_secret"

# ==========================================
# JWT Expiry
# ==========================================

JWT_EXPIRES=7d

# ==========================================
# Server Port
# ==========================================

PORT=5000

# ==========================================
# Environment
# ==========================================

NODE_ENV=development